<!--
  Status-bar (small) notification icon: the Chatterloop converging-arrows mark.

  Android masks this to its ALPHA CHANNEL and paints the result in the system
  accent colour - all colour information is discarded. That's why this is a
  flat white silhouette on transparency, and why the brand's blue/grey split
  can't survive here: all four arrows render as one colour regardless.

  Simplified from assets/images/chatterloop.png in two ways, both deliberate
  for a mark that renders around 24dp in a status bar: the four arms are made
  symmetric (the source has a shorter left arm), and the corner rounding is
  dropped, since neither survives at this size and both cost legibility.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- top arm, pointing down toward centre -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M9.8,2 L14.2,2 L14.2,6.8 L16.4,6.8 L12,10.6 L7.6,6.8 L9.8,6.8 Z" />
    <!-- bottom arm, pointing up -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M9.8,22 L14.2,22 L14.2,17.2 L16.4,17.2 L12,13.4 L7.6,17.2 L9.8,17.2 Z" />
    <!-- left arm, pointing right -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M2,9.8 L2,14.2 L6.8,14.2 L6.8,16.4 L10.6,12 L6.8,7.6 L6.8,9.8 Z" />
    <!-- right arm, pointing left -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M22,9.8 L22,14.2 L17.2,14.2 L17.2,16.4 L13.4,12 L17.2,7.6 L17.2,9.8 Z" />
</vector>
